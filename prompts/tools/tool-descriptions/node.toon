@tool{
  name:node
  category:system
  description:Execute a Node.js (ESM) code snippet and return stdout/stderr.
  params:{
    code:string (required) — Node.js ESM code to execute
  }
  hint:Use for JavaScript computations, JSON manipulation, or Node.js-specific tasks like Buffer, crypto, etc.
}
